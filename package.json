{
	"name": "vue3-boilerplate",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"preview": "vite preview",
		"build": "vite build",
		"type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
    "stylelint": "stylelint src/**/*.{scss,vue} --fix",
    "eslint": "eslint . --ext .vue,.js,.cjs --fix --quiet --ignore-path .gitignore",
    "lint": "npm run type-check && npm run eslint && npm run stylelint"
	},
	"devDependencies": {
    "@mapbox/stylelint-processor-arbitrary-tags": "0.4.0",
		"@rushstack/eslint-patch": "1.3.3",
    "@stylistic/eslint-plugin": "1.6.3",
    "@stylistic/stylelint-config": "1.0.1",
		"@tsconfig/node18": "18.2.2",
		"@types/clone-deep": "4.0.2",
		"@types/node": "18.17.17",
    "@vitejs/plugin-vue": "5.0.3",
		"@vue/eslint-config-typescript": "12.0.0",
		"@vue/tsconfig": "0.4.0",
    "autoprefixer": "10.4.18",
		"clone-deep": "4.0.1",
		"eslint": "8.49.0",
		"eslint-plugin-vue": "9.17.0",
		"pinia": "2.1.7",
		"postcss-html": "1.6.0",
		"postcss-scss": "4.0.9",
		"postcss-sort-media-queries": "5.2.0",
		"postcss-url": "10.1.3",
		"pre-commit": "1.2.2",
    "sass": "1.71.1",
    "stylelint": "16.2.1",
    "stylelint-config-standard": "36.0.0",
    "stylelint-order-htmlacademy": "2.1.0",
		"typescript": "5.2.2",
    "vite": "^5.0.11",
    "vue": "3.4.15",
    "vue-router": "4.2.5",
		"vue-tsc": "1.8.11"
	},
  "pre-commit": "lint",
  "browserslist": [
    "> 1%",
    "last 2 version"
  ]
}
